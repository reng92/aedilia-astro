---
import sito from '../data/sito.json';
---
<footer class="w-full bg-[#1C1C1C] px-8 md:px-24 pt-20 pb-10">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 pb-16 border-b border-gray-800">
      <div class="md:col-span-1">
        <p class="text-xs font-light text-gray-300 leading-relaxed">
          Infrastrutture stradali, TLC, reti idriche e segnaletica.<br>
          Caserta, Napoli e tutta la Campania.
        </p>
      </div>
      <div>
        <p class="text-xs font-medium tracking-widest uppercase text-gray-200 mb-6">Servizi</p>
        <ul class="space-y-3 text-xs font-light text-gray-300">
          <li><a href="/servizi" class="hover:text-[#E8D9AA] transition-colors">Pavimentazioni in asfalto</a></li>
          <li><a href="/servizi" class="hover:text-[#E8D9AA] transition-colors">Infrastrutture TLC</a></li>
          <li><a href="/servizi" class="hover:text-[#E8D9AA] transition-colors">Acquedotto e fognature</a></li>
          <li><a href="/servizi" class="hover:text-[#E8D9AA] transition-colors">Arredo urbano</a></li>
          <li><a href="/servizi" class="hover:text-[#E8D9AA] transition-colors">Segnaletica non luminosa</a></li>
          <li><a href="/servizi" class="hover:text-[#E8D9AA] transition-colors">Manutenzione strade</a></li>
        </ul>
      </div>
      <div>
        <p class="text-xs font-medium tracking-widest uppercase text-gray-200 mb-6">Azienda</p>
        <ul class="space-y-3 text-xs font-light text-gray-300">
          <li><a href="/chi-siamo" class="hover:text-[#E8D9AA] transition-colors">Chi siamo</a></li>
          <li><a href="/portfolio" class="hover:text-[#E8D9AA] transition-colors">Portfolio lavori</a></li>
          <li><a href="/contatti" class="hover:text-[#E8D9AA] transition-colors">Contatti</a></li>
          <li><a href="/privacy-policy" class="hover:text-[#E8D9AA] transition-colors">Privacy policy</a></li>
          <li>
            <button type="button" data-cc="show-preferencesModal" class="hover:text-[#E8D9AA] transition-colors text-left">
              Preferenze cookie
            </button>
          </li>
        </ul>
      </div>
      <div>
        <p class="text-xs font-medium tracking-widest uppercase text-gray-200 mb-6">Contatti</p>
        <ul class="space-y-3 text-xs font-light text-gray-300">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-[#C9B98A] mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
            <span>{sito.indirizzo}, {sito.localita} ({sito.provincia})</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-[#C9B98A] mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            <a href={`tel:${sito.telefonoRaw}`} class="hover:text-[#E8D9AA] transition-colors">{sito.telefono}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-[#C9B98A] mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
            <a href={`mailto:${sito.email}`} class="hover:text-[#E8D9AA] transition-colors">{sito.email}</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 flex flex-col gap-3 border-t border-gray-800">
      <p class="text-xs font-light text-gray-200">
        © {new Date().getFullYear()} {sito.ragioneSociale} — Tutti i diritti riservati
      </p>
      <p class="text-xs font-light text-gray-300">
        Sede legale: {sito.indirizzo} - {sito.cap} {sito.localita} ({sito.provincia}) —
        P.IVA {sito.piva} — REA {sito.rea} — Cap. Soc. {sito.capSociale} —
        <a href={`mailto:${sito.pec}`} class="hover:text-gray-100 transition-colors">PEC: {sito.pec}</a>
      </p>
      <div class="flex flex-col md:flex-row md:justify-between md:items-center gap-2">
        <p class="text-xs font-light text-gray-300">
          <a href="/privacy-policy" class="hover:text-gray-100 transition-colors">Privacy Policy</a>
          &nbsp;·&nbsp;
          <a href="/cookie-policy" class="hover:text-gray-100 transition-colors">Cookie Policy</a>
          &nbsp;·&nbsp;
          <a href="/accessibilita" class="hover:text-gray-100 transition-colors">Accessibilità</a>
          &nbsp;·&nbsp;
          Caserta · Napoli · Campania
        </p>
        <p class="text-xs font-light text-gray-300">
          Made with ❤️ by
          <a href="https://traccestudio.it" target="_blank" rel="noopener noreferrer" class="hover:text-[#E8D9AA] transition-colors">
            Tracce Web Agency
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
