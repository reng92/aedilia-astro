---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import home from '../data/home.json';

const allPortfolio = await getCollection('portfolio');
const previewItems = allPortfolio.slice(0, 4);
---

<Layout title="Home" description="Aedilia Costruzioni — Pavimentazioni in asfalto, infrastrutture TLC, acquedotto, fognature e segnaletica in Campania dal 1978.">

  <style>
    .hero-bg { transition: transform 0.1s linear; }
    .hero-line { width: 0; height: 2px; background: #C9B98A; animation: expandLine 1.2s cubic-bezier(0.16,1,0.3,1) 0.3s forwards; }
    @keyframes expandLine { from { width: 0; } to { width: 4rem; } }
    .hero-section { opacity: 0; animation: heroFadeIn 1s cubic-bezier(0.16,1,0.3,1) 0.1s forwards; }
    @keyframes heroFadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  </style>

  <!-- HERO -->
  <section class="relative w-full h-[100svh] overflow-hidden hero-section noise">
    <div class="absolute inset-0 bg-gray-300">
      <img src="/images/hero.jpg" alt="Aedilia Costruzioni" class="w-full h-full object-cover hero-bg" style="will-change: transform;">
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-transparent"></div>
    <div class="relative z-10 h-full flex flex-col justify-end pt-24 pb-6 md:pb-10 px-8 md:px-24 max-w-7xl">
      <div class="hero-line mb-6"></div>
      <p class="text-xs font-medium tracking-[0.3em] uppercase text-[#C9B98A] mb-4">{home.heroTag}</p>
      <h1 class="text-5xl md:text-7xl font-light text-white leading-tight">
        <span class="reveal-line" style="display:block; overflow:hidden;"><span class="reveal-inner" style="display:block;">{home.heroLine1}</span></span>
        <span class="reveal-line" style="display:block; overflow:hidden;"><span class="reveal-inner" style="display:block;">che <span style="color:#C9B98A; font-style:italic;">{home.heroLine2}</span></span></span>
        <span class="reveal-line" style="display:block; overflow:hidden;"><span class="reveal-inner" style="display:block;">{home.heroLine3}</span></span>
        <span class="reveal-line" style="display:block; overflow:hidden;"><span class="reveal-inner" style="display:block;">che <span style="color:#C9B98A; font-style:italic;">{home.heroLine4}</span></span></span>
      </h1>
      <p data-aos="fade-up" data-aos-delay="200" data-aos-duration="1000" class="text-sm md:text-base font-light text-white/60 max-w-xl leading-relaxed mb-10">
        {home.heroDescription}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mb-6 md:mb-16">
        <a data-aos="fade-up" data-aos-delay="400" data-aos-duration="1000" href="/contatti" class="inline-block border border-[#C9B98A] text-[#C9B98A] text-xs font-medium tracking-widest uppercase px-8 py-4 hover:bg-[#C9B98A] hover:text-white transition-all duration-300 magnetic">
          Preventivo gratuito
        </a>
        <a href="/servizi" class="inline-block text-white/60 text-xs font-medium tracking-widest uppercase px-8 py-4 hover:text-white transition-all duration-300 magnetic">
          Scopri i servizi →
        </a>
      </div>
    </div>
  </section>

  <!-- TICKER -->
  <div class="w-full overflow-hidden bg-[#0D0D0D] py-4 border-y border-gray-800">
    <div class="flex whitespace-nowrap">
      <div class="ticker-track flex items-center gap-12 pr-12 text-xs font-medium tracking-[0.25em] uppercase text-[#C9B98A]">
        <span>Pavimentazioni in asfalto</span><span class="text-gray-700">·</span>
        <span>Infrastrutture TLC</span><span class="text-gray-700">·</span>
        <span>Acquedotto e fognature</span><span class="text-gray-700">·</span>
        <span>Arredo urbano</span><span class="text-gray-700">·</span>
        <span>Segnaletica stradale</span><span class="text-gray-700">·</span>
        <span>Manutenzione strade</span><span class="text-gray-700">·</span>
      </div>
    </div>
  </div>

  <!-- CHI SIAMO -->
  <section class="w-full py-24 px-8 md:px-24 bg-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <img src="/images/gallery-03.jpg" alt="Aedilia Costruzioni al lavoro"
             class="w-full h-[280px] md:h-[480px] object-cover chi-siamo-img">
        <div class="absolute -bottom-6 -right-6 bg-[#C9B98A] w-32 h-32 -z-10"></div>
      </div>
      <div class="reveal">
        <p class="text-xs font-medium tracking-[0.3em] uppercase text-[#C9B98A] mb-4">Chi siamo</p>
        <h2 data-aos="fade-up" class="text-3xl md:text-4xl font-light text-gray-900 leading-snug mb-6">
          Costruiamo le infrastrutture<br>
          <span class="font-normal">che tengono in piedi il territorio.</span>
        </h2>
        <p data-aos="fade-up" data-aos-delay="100" class="text-sm font-light text-gray-500 leading-relaxed mb-4">
          Aedilia Costruzioni opera dal 1978 nelle province di Caserta e Napoli, con interventi su tutto il territorio campano. Realizziamo opere pubbliche e private con competenza, attrezzature proprie e personale specializzato.
        </p>
        <p class="text-sm font-light text-gray-500 leading-relaxed mb-10">
          Dalla pavimentazione in asfalto alla posa di reti idriche e cavidotti TLC, offriamo un servizio completo: progettazione, esecuzione e manutenzione.
        </p>
        <a href="/contatti" class="inline-block border border-gray-900 text-gray-900 text-xs font-medium tracking-widest uppercase px-8 py-4 hover:bg-gray-900 hover:text-white transition-all duration-300">
          Richiedi un preventivo
        </a>
      </div>
    </div>
  </section>

  <!-- 3 VALORI -->
  <section class="w-full py-16 px-8 md:px-24 bg-[#F8F6F1] border-y border-gray-100">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10">
      <div data-aos="fade-up" data-aos-delay="0" class="reveal flex flex-col items-start gap-3">
        <svg class="w-8 h-8 text-[#C9B98A]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-xs font-medium tracking-widest uppercase text-gray-400">Preventivo</p>
        <p class="text-sm font-light text-gray-600 leading-relaxed">Sopralluogo e preventivo gratuiti, senza impegno, in tempi rapidi.</p>
      </div>
      <div data-aos="fade-up" data-aos-delay="150" class="reveal flex flex-col items-start gap-3">
        <svg class="w-8 h-8 text-[#C9B98A]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/>
        </svg>
        <p class="text-xs font-medium tracking-widest uppercase text-gray-400">Consulenza</p>
        <p class="text-sm font-light text-gray-600 leading-relaxed">Consulenza tecnica specializzata per ogni tipo di intervento infrastrutturale.</p>
      </div>
      <div data-aos="fade-up" data-aos-delay="300" class="reveal flex flex-col items-start gap-3">
        <svg class="w-8 h-8 text-[#C9B98A]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
        </svg>
        <p class="text-xs font-medium tracking-widest uppercase text-gray-400">Operatività</p>
        <p class="text-sm font-light text-gray-600 leading-relaxed">Caserta, Napoli e tutta la Campania. Interveniamo dove serve, quando serve.</p>
      </div>
    </div>
  </section>

  <!-- SERVIZI ORIZZONTALI -->
  <section class="w-full bg-white">
    <!-- MOBILE -->
    <div class="md:hidden w-full px-6 py-12 flex flex-col gap-4">
      {[
        ['01','Pavimentazioni in asfalto','Asfalto normale e stampato per strade pubbliche, piazzali privati e aree residenziali.'],
        ['02','Infrastrutture TLC','Cavidotti, fibre ottiche e infrastrutture per telecomunicazioni.'],
        ['03','Acquedotto e fognature','Reti idriche, fognature e cavidotti su nuove costruzioni e infrastrutture esistenti.'],
        ['04','Arredo urbano','Installazione e manutenzione arredi urbani, aiuole e aree pedonali.'],
        ['05','Segnaletica non luminosa','Strisce pedonali, dossi artificiali, cartelli stradali e delimitazioni cantiere.'],
        ['06','Manutenzione strade','Manutenzione ordinaria e straordinaria su strade comunali e private.'],
      ].map(([n, t, d]) => (
        <div class="bg-[#F8F6F1] p-8 flex flex-col gap-4">
          <span class="text-2xl font-light text-[#C9B98A]">{n}</span>
          <h3 class="text-sm font-medium text-gray-900">{t}</h3>
          <p class="text-xs font-light text-gray-500 leading-relaxed">{d}</p>
        </div>
      ))}
    </div>

    <!-- DESKTOP: horizontal scroll pinned -->
    <div class="hidden md:block services-horizontal overflow-hidden">
      <div class="services-track flex gap-6 px-24 py-24 w-max items-stretch">
        {[
          ['01','Pavimentazioni in asfalto','Asfalto normale e stampato per strade pubbliche, piazzali privati e aree residenziali. Posa e manutenzione.'],
          ['02','Infrastrutture TLC','Realizzazione di cavidotti, posa di fibre ottiche e infrastrutture per telecomunicazioni su territorio urbano ed extraurbano.'],
          ['03','Acquedotto e fognature','Posa di reti idriche, fognature e cavidotti. Interventi su infrastrutture esistenti e nuove costruzioni.'],
          ['04','Arredo urbano','Installazione e manutenzione di arredi urbani, aiuole, pavimentazioni decorative e aree pedonali.'],
          ['05','Segnaletica non luminosa','Segnaletica orizzontale e verticale: strisce pedonali, cartelli stradali, dossi artificiali e delimitazioni di cantiere.'],
          ['06','Manutenzione strade','Interventi di manutenzione ordinaria e straordinaria su strade comunali e private. Rattoppi, rifacimenti e drenaggi.'],
        ].map(([n, t, d]) => (
          <div class="w-[380px] shrink-0 bg-[#F8F6F1] p-10 flex flex-col gap-6">
            <span class="text-3xl font-light text-[#C9B98A]">{n}</span>
            <h3 class="text-base font-medium text-gray-900">{t}</h3>
            <p class="text-sm font-light text-gray-500 leading-relaxed">{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PORTFOLIO PREVIEW -->
  <section class="w-full py-24 px-8 md:px-24 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
        <div>
          <p class="text-xs font-medium tracking-[0.3em] uppercase text-[#C9B98A] mb-4">I nostri lavori</p>
          <h2 data-aos="fade-up" class="text-3xl md:text-4xl font-light text-gray-900 leading-snug">
            Opere realizzate<br><span class="font-normal">in tutta la Campania.</span>
          </h2>
        </div>
        <a href="/portfolio" class="inline-block border border-gray-900 text-gray-900 text-xs font-medium tracking-widest uppercase px-8 py-4 hover:bg-gray-900 hover:text-white transition-all duration-300 whitespace-nowrap self-start md:self-auto">
          Vedi tutti i lavori
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-1">
        {previewItems.slice(0,1).map(item => (
          <div data-aos="fade-up" data-aos-delay="0" class="lg:col-span-2 overflow-hidden">
            <div class="portfolio-card h-[400px]">
              <img src={item.data.image} alt={item.data.title} class="w-full h-full object-cover">
              <div class="portfolio-overlay"><p>{item.data.description}</p></div>
            </div>
          </div>
        ))}
        {previewItems.slice(1,2).map(item => (
          <div data-aos="fade-up" data-aos-delay="100" class="overflow-hidden">
            <div class="portfolio-card h-[400px]">
              <img src={item.data.image} alt={item.data.title} class="w-full h-full object-cover">
              <div class="portfolio-overlay"><p>{item.data.description}</p></div>
            </div>
          </div>
        ))}
        {previewItems.slice(2,3).map(item => (
          <div data-aos="fade-up" data-aos-delay="200" class="overflow-hidden">
            <div class="portfolio-card h-[400px]">
              <img src={item.data.image} alt={item.data.title} class="w-full h-full object-cover">
              <div class="portfolio-overlay"><p>{item.data.description}</p></div>
            </div>
          </div>
        ))}
        {previewItems.slice(3,4).map(item => (
          <div data-aos="fade-up" data-aos-delay="300" class="lg:col-span-2 overflow-hidden">
            <div class="portfolio-card h-[400px]">
              <img src={item.data.image} alt={item.data.title} class="w-full h-full object-cover">
              <div class="portfolio-overlay"><p>{item.data.description}</p></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA CONTATTI -->
  <section class="w-full py-32 px-8 md:px-24 bg-[#C9B98A] relative overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none overflow-hidden">
      <span class="text-[20vw] font-black text-[#0D0D0D]/[0.04] tracking-tighter uppercase leading-none whitespace-nowrap">AEDILIA</span>
    </div>
    <div class="reveal relative max-w-4xl mx-auto text-center">
      <p class="text-xs font-medium tracking-[0.3em] uppercase text-[#0D0D0D]/60 mb-6">Parliamo del tuo progetto</p>
      <h2 data-aos="fade-up" class="text-4xl md:text-6xl font-light text-[#0D0D0D] leading-tight mb-10">
        Hai un lavoro<br><span class="font-normal italic">da realizzare?</span>
      </h2>
      <p class="text-sm font-light text-[#0D0D0D]/70 max-w-xl mx-auto mb-12 leading-relaxed">
        Contattaci per un sopralluogo gratuito. Interveniamo nelle province di Caserta e Napoli e su tutto il territorio campano, per lavori pubblici e privati.
      </p>
      <div data-aos="fade-up" data-aos-delay="150" class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contatti" class="inline-block bg-[#0D0D0D] text-white text-xs font-medium tracking-widest uppercase px-10 py-5 hover:bg-white hover:text-[#0D0D0D] transition-all duration-300">
          Richiedi preventivo gratuito
        </a>
        <a href="tel:+393270294375" class="inline-block border border-[#0D0D0D]/30 text-[#0D0D0D] text-xs font-medium tracking-widest uppercase px-10 py-5 hover:border-[#0D0D0D] hover:bg-[#0D0D0D] hover:text-white transition-all duration-300">
          Chiamaci ora
        </a>
      </div>
    </div>
  </section>

</Layout>
