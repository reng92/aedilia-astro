---
import Layout from '../layouts/Layout.astro';
import sito from '../data/sito.json';
---

<Layout
  title="Contatti"
  description="Contatta Aedilia Costruzioni per un preventivo gratuito. Telefono, WhatsApp ed email. Operiamo nelle province di Caserta, Napoli e in tutta la Campania."
>

  <!-- HERO MINI -->
  <section class="w-full pt-24 md:pt-40 pb-20 px-8 md:px-24 bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto">
      <div class="w-16 h-px bg-[#C9B98A] mb-6"></div>
      <p class="text-xs font-medium tracking-[0.3em] uppercase text-gray-400 mb-4">Contatti</p>
      <h1 class="text-3xl md:text-5xl font-light text-gray-900 leading-tight">
        Parliamo del<br>
        <span class="font-normal">tuo progetto.</span>
      </h1>
    </div>
  </section>

  <!-- CONTATTI PRINCIPALI -->
  <section class="w-full py-12 md:py-24 px-8 md:px-24 bg-white">
    <div class="max-w-7xl mx-auto">

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">

        <!-- WhatsApp -->
        <a data-aos="fade-up" data-aos-delay="0" href={`https://wa.me/${sito.whatsapp}`} target="_blank" rel="noopener"
           class="group flex flex-col gap-6 p-10 bg-[#C9B98A] hover:bg-[#b8a678] transition-all duration-300">
          <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <div>
            <p class="text-xs font-medium tracking-widest uppercase text-white/70 mb-2">WhatsApp</p>
            <p class="text-2xl font-light text-white">{sito.telefono}</p>
            <p class="text-sm font-light text-white/70 mt-2">Scrivici su WhatsApp →</p>
          </div>
        </a>

        <!-- Telefono -->
        <a data-aos="fade-up" data-aos-delay="150" href={`tel:${sito.telefonoRaw}`}
           class="group flex flex-col gap-6 p-10 bg-[#F8F6F1] hover:bg-[#ede9e0] transition-all duration-300">
          <svg class="w-10 h-10 text-[#C9B98A]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          <div>
            <p class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-2">Telefono</p>
            <p class="text-2xl font-light text-gray-900">{sito.telefono}</p>
            <p class="text-sm font-light text-gray-400 mt-2">Chiamaci direttamente →</p>
          </div>
        </a>

        <!-- Email -->
        <a data-aos="fade-up" data-aos-delay="300" href={`mailto:${sito.email}`}
           class="group flex flex-col gap-6 p-10 bg-[#F8F6F1] hover:bg-[#ede9e0] transition-all duration-300">
          <svg class="w-10 h-10 text-[#C9B98A]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
          <div>
            <p class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-2">Email</p>
            <p class="text-xl font-light text-gray-900 break-all">{sito.email}</p>
            <p class="text-sm font-light text-gray-400 mt-2">Scrivici per email →</p>
          </div>
        </a>

      </div>

      <!-- Info azienda -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 pt-16 border-t border-gray-100">
        <div data-aos="fade-up" data-aos-delay="0">
          <p class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-6">Sede legale</p>
          <p class="text-sm font-light text-gray-600 leading-relaxed">
            {sito.ragioneSociale}<br>
            {sito.indirizzo}<br>
            {sito.cap} {sito.localita} ({sito.provincia})<br>
            P.IVA {sito.piva} — REA {sito.rea}
          </p>
        </div>
        <div data-aos="fade-up" data-aos-delay="150">
          <p class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-6">Zona operativa</p>
          <p class="text-sm font-light text-gray-600 leading-relaxed">
            Operiamo principalmente nelle province di<br>
            <strong class="text-gray-800 font-medium">Caserta</strong> e <strong class="text-gray-800 font-medium">Napoli</strong>,<br>
            con interventi su tutta la <strong class="text-gray-800 font-medium">Campania</strong>.<br><br>
            PEC: <a href={`mailto:${sito.pec}`} class="text-[#C9B98A] hover:text-gray-900 transition-colors">{sito.pec}</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINALE -->
  <section class="w-full py-12 md:py-24 px-8 md:px-24 bg-[#F8F6F1]">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl md:text-4xl font-light text-gray-900 leading-snug mb-8">
        Rispondiamo entro poche ore.
      </h2>
      <a href={`https://wa.me/${sito.whatsapp}`} target="_blank" rel="noopener"
         class="inline-block bg-[#C9B98A] text-white text-xs font-medium tracking-widest uppercase px-10 py-5 hover:bg-[#1C1C1C] transition-all duration-300">
        Scrivici su WhatsApp
      </a>
    </div>
  </section>

</Layout>
