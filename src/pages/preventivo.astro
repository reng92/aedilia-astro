---
import Layout from '../layouts/Layout.astro';
import sito from '../data/sito.json';

const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '1x00000000000000000000AA';

const servizi = [
  'Pavimentazioni in asfalto',
  'Infrastrutture TLC',
  'Acquedotto e fognature',
  'Segnaletica stradale',
  'Arredo urbano',
  'Manutenzione strade',
  'Altro',
];
---

<Layout
  title="Richiedi un preventivo"
  description="Richiedi un preventivo gratuito ad Aedilia Costruzioni. Pavimentazioni, infrastrutture stradali, TLC, acquedotto e segnaletica nelle province di Caserta e Napoli."
>

  <!-- HERO MINI -->
  <section class="w-full pt-24 md:pt-40 pb-20 px-8 md:px-24 bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto">
      <div class="w-16 h-px bg-[#C9B98A] mb-6"></div>
      <p class="text-xs font-medium tracking-[0.3em] uppercase text-gray-400 mb-4">Preventivo gratuito</p>
      <h1 class="text-3xl md:text-5xl font-light text-gray-900 leading-tight">
        Dimmi di cosa<br>
        <span class="font-normal">hai bisogno.</span>
      </h1>
      <p class="mt-6 text-sm font-light text-gray-500 max-w-xl leading-relaxed">
        Compila il form e ti risponderemo entro poche ore. Il preventivo è sempre gratuito e senza impegno.
      </p>
    </div>
  </section>

  <!-- FORM (temporaneamente nascosto) -->
  {/*
  <section class="w-full py-16 md:py-24 px-8 md:px-24 bg-white">
