      >

        <!-- SUCCESS STATE -->
        <div x-show="success" x-transition class="py-16 text-center" style="display:none">
          <div class="w-16 h-px bg-[#C9B98A] mx-auto mb-8"></div>
          <p class="text-xs font-medium tracking-[0.3em] uppercase text-gray-400 mb-4">Richiesta inviata</p>
          <h2 class="text-2xl md:text-3xl font-light text-gray-900 mb-6">Grazie, abbiamo ricevuto<br>la tua richiesta.</h2>
          <p class="text-sm font-light text-gray-500 leading-relaxed mb-10">
            Ti risponderemo a breve all'indirizzo email indicato.<br>
            Per urgenze puoi scriverci su WhatsApp.
          </p>
          <a href={`https://wa.me/${sito.whatsapp}`} target="_blank" rel="noopener"
             class="inline-block bg-[#C9B98A] text-white text-xs font-medium tracking-widest uppercase px-10 py-5 hover:bg-[#1C1C1C] transition-all duration-300">
