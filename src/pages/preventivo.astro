                </span>
              </label>
            </div>

            <!-- Turnstile CAPTCHA -->
            <div class="md:col-span-2">
              <div
                class="cf-turnstile"
                data-sitekey={siteKey}
                data-theme="light"
                data-language="it"
                data-size="normal"
              ></div>
              <p class="mt-3 text-xs font-light text-gray-400">
                Verifica di sicurezza • Cloudflare Turnstile — nessun cookie, conforme GDPR/UE.
              </p>
            </div>

          </div>

          <!-- Error message -->
