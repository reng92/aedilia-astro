  <!-- INFO STRIP -->
  <section class="w-full py-12 md:py-16 px-8 md:px-24 bg-[#F8F6F1] border-t border-gray-100">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div data-aos="fade-up" data-aos-delay="0">
          <p class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-3">Risposta rapida</p>
          <p class="text-sm font-light text-gray-600 leading-relaxed">Rispondiamo generalmente entro poche ore nei giorni lavorativi.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="150">
          <p class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-3">Preventivo gratuito</p>
          <p class="text-sm font-light text-gray-600 leading-relaxed">Nessun costo, nessun impegno. Valutiamo ogni richiesta con cura.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="300">
          <p class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-3">Zona operativa</p>
          <p class="text-sm font-light text-gray-600 leading-relaxed">Province di <strong class="text-gray-800 font-medium">Caserta</strong> e <strong class="text-gray-800 font-medium">Napoli</strong>, tutta la Campania.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<!-- Cloudflare Turnstile SDK -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
