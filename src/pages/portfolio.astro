---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('portfolio');
const sorted = items.sort((a, b) => a.id.localeCompare(b.id));

// Serialize for Alpine
const itemsJson = JSON.stringify(sorted.map(i => ({
  id: i.id,
  title: i.data.title,
  category: i.data.category,
  location: i.data.location,
  image: i.data.image,
  description: i.data.description ?? `${i.data.title} · ${i.data.location}`,
})));
---

<Layout
  title="Portfolio"
  description="Galleria lavori di Aedilia Costruzioni. Pavimentazioni, infrastrutture TLC, reti idriche e segnaletica nelle province di Caserta e Napoli."
>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" slot="head">

  <!-- HERO MINI -->
  <section class="w-full pt-24 md:pt-40 pb-20 px-8 md:px-24 bg-[#F5EFE2]">
    <div class="max-w-7xl mx-auto">
      <p class="text-xs font-medium tracking-[0.3em] uppercase text-[#B89B5E] mb-4">Portfolio</p>
      <h1 class="text-4xl md:text-6xl font-light text-[#0D0D0D] leading-tight">
        I nostri lavori<br>
        <span class="font-normal italic">parlano per noi.</span>
      </h1>
    </div>
  </section>

  <!-- FILTRI + GRIGLIA -->
  <section class="w-full py-10 px-8 md:px-24 bg-white border-b border-gray-100"
           x-data={`{ active: 'tutti', items: ${itemsJson} }`}>
    <div class="max-w-7xl mx-auto flex flex-wrap gap-3">
      {['tutti','asfalto','segnaletica','strade','tlc','acquedotto','arredo'].map(cat => (
        <button
          @click={`active = '${cat}'`}
          :class={`active === '${cat}' ? 'bg-gray-900 text-white' : 'text-gray-500 hover:text-gray-900'`}
          class="text-xs font-medium tracking-widest uppercase px-5 py-2.5 border border-gray-200 hover:border-gray-900 transition-all duration-200"
        >
          {cat === 'tutti' ? 'Tutti' : cat.charAt(0).toUpperCase() + cat.slice(1)}
        </button>
      ))}
    </div>

    <!-- GRIGLIA -->
    <div class="max-w-7xl mx-auto mt-16 pb-24">
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-2 space-y-2">
        <template x-for="item in items" :key="item.id">
          <div
            x-show="active === 'tutti' || active === item.category"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100"
            class="break-inside-avoid group relative overflow-hidden"
          >
            <a :href="item.image" class="glightbox" data-gallery="aedilia" :data-description="item.description">
              <img :src="item.image" :alt="item.title"
                   class="w-full object-cover group-hover:scale-105 transition-transform duration-700">
              <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
                <p class="text-white text-xs font-medium tracking-widest uppercase" x-text="item.title"></p>
                <p class="text-[#C9B98A] text-xs font-light mt-1" x-text="item.location"></p>
              </div>
            </a>
          </div>
        </template>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="w-full py-12 md:py-24 px-8 md:px-24 bg-[#F5EFE2]">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl md:text-4xl font-light text-[#0D0D0D] leading-snug mb-8">
        Vuoi un lavoro come questi?
      </h2>
      <a href="/contatti" class="inline-block bg-[#B89B5E] text-white text-xs font-medium tracking-widest uppercase px-10 py-5 hover:bg-[#a98c52] transition-all duration-300">
        Richiedi preventivo gratuito
      </a>
    </div>
  </section>

  <script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      if (typeof GLightbox !== 'undefined') {
        GLightbox({ touchNavigation: true, loop: true, autoplayVideos: false });
      }
    });
  </script>

</Layout>
